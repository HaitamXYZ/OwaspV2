{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist/owasp-asvs-app/browser",
    "installCommand": "npm install && cd server && npm install",
    "rewrites": [
        { "source": "/api/(.*)", "destination": "/api" },
        { "source": "/(.*)", "destination": "/index.html" }
    ]
}
